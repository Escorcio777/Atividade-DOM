<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Atividade DOM Interativa</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f6f8;
      padding: 20px;
    }

    h1 {
      color: #333;
    }

    .box {
      background: #fff;
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 8px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    button {
      padding: 8px 12px;
      margin: 5px;
      cursor: pointer;
      border: none;
      border-radius: 5px;
      background: #007bff;
      color: white;
    }

    button:hover {
      background: #0056b3;
    }

    input, select {
      padding: 8px;
      margin-top: 10px;
      width: 100%;
      box-sizing: border-box;
    }

    .contador {
      font-size: 20px;
      font-weight: bold;
      margin-left: 10px;
    }

    .charCount {
      font-size: 14px;
      color: #555;
    }
  </style>
</head>
<body>

  <h1>Manipulação do DOM</h1>

  <!-- CONTADOR -->
  <div class="box">
    <h2>Contador de Cliques</h2>
    <button id="btnAdd">+</button>
    <button id="btnSub">-</button>
    <span class="contador" id="contador">0</span>
  </div>

  <!-- TEXTO DINÂMICO -->
  <div class="box">
    <h2>Adicionar Texto</h2>
    <input type="text" id="inputTexto" placeholder="Digite algo e pressione Enter">
    <p class="charCount">Caracteres (sem espaço): <span id="charCount">0</span></p>
    <div id="saidaTexto"></div>
  </div>

  <!-- LISTA -->
  <div class="box">
    <h2>Adicionar Lista</h2>
    <select id="tipoLista">
      <option value="ul">Lista não ordenada</option>
      <option value="ol">Lista ordenada</option>
    </select>
    <button id="btnLista">Adicionar Lista</button>
    <div id="areaLista"></div>
  </div>

  <!-- RESET -->
  <div class="box">
    <button id="btnReset">Resetar Tudo</button>
  </div>

<script>
  // =========================
  // SELEÇÃO DE ELEMENTOS
  // =========================
  const contadorEl = document.getElementById("contador");
  const btnAdd = document.getElementById("btnAdd");
  const btnSub = document.getElementById("btnSub");

  const inputTexto = document.getElementById("inputTexto");
  const saidaTexto = document.getElementById("saidaTexto");
  const charCountEl = document.getElementById("charCount");

  const tipoLista = document.getElementById("tipoLista");
  const btnLista = document.getElementById("btnLista");
  const areaLista = document.getElementById("areaLista");

  const btnReset = document.getElementById("btnReset");

  // =========================
  // ESTADO
  // =========================
  let contador = 0;

  // =========================
  // CONTADOR
  // =========================
  btnAdd.addEventListener("click", () => {
    contador++;
    atualizarContador();
  });

  btnSub.addEventListener("click", () => {
    if (contador === 0) {
      alert("O contador já está em zero!");
      return;
    }
    contador--;
    atualizarContador();
  });

  function atualizarContador() {
    contadorEl.textContent = contador;
  }

  // =========================
  // TEXTO DINÂMICO + ENTER
  // =========================
  inputTexto.addEventListener("keydown", (event) => {
    if (event.key === "Enter") {
      if (inputTexto.value.trim() === "") return;

      const p = document.createElement("p");
      p.textContent = inputTexto.value;

      saidaTexto.appendChild(p);
      inputTexto.value = "";
      atualizarCharCount();
    }
  });

  // =========================
  // CONTADOR DE CARACTERES
  // =========================
  inputTexto.addEventListener("input", atualizarCharCount);

  function atualizarCharCount() {
    const texto = inputTexto.value.replace(/\s/g, "");
    charCountEl.textContent = texto.length;
  }

  // =========================
  // ADICIONAR LISTA
  // =========================
  btnLista.addEventListener("click", () => {
    const tipo = tipoLista.value;
    const lista = document.createElement(tipo);

    // cria itens exemplo
    for (let i = 1; i <= 3; i++) {
      const li = document.createElement("li");
      li.textContent = `Item ${i}`;
      lista.appendChild(li);
    }

    areaLista.appendChild(lista);
  });

  // =========================
  // RESET
  // =========================
  btnReset.addEventListener("click", () => {
    contador = 0;
    atualizarContador();

    saidaTexto.innerHTML = "";
    areaLista.innerHTML = "";
    inputTexto.value = "";
    atualizarCharCount();
  });

</script>

</body>
</html>
